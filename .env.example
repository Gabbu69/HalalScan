# GEMINI_API_KEY: Required for Gemini AI API calls.
# Required in Vercel Project Settings -> Environment Variables.
# Keep this server-side only. Do not use VITE_GEMINI_API_KEY.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional supported aliases if you already use one of these names in Vercel:
# GOOGLE_API_KEY="MY_GEMINI_API_KEY"
# GOOGLE_GENERATIVE_AI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
